            btn.innerText = "제출중입니다";
            btn.disabled = true;

            // [주의] 하단 가이드라인 3단계를 수행한 뒤 획득한 배포 URL을 이곳에 교체해 넣으세요.
            const url = "https://script.google.com/macros/s/AKfycbwYjp_kucLa_wO4P4m4Z1bLm5lgnVjEEXV8W0oewOzDOFFSf67IsqmF6NovjQXSuLpx/exec";
            
            const payload = {
                student_name: document.getElementById('student_name').value,
                parent_name: document.getElementById('parent_name').value,
                phone_full: document.getElementById('phone_prefix').value + "-" + document.getElementById('phone_number').value,
                school_grade: document.getElementById('school_grade').value,
                student_grade_level: document.getElementById('student_grade_level').value,
                target_subject: document.getElementById('target_subject').value,
                weakness_desc: document.getElementById('weakness_desc').value,
                consulting_time: document.getElementById('consulting_time').value
            };

            fetch(`${url}?${new URLSearchParams(payload).toString()}`, { method: 'POST', mode: 'no-cors' })
            .then(() => { 
                alert("제출이 완료되었습니다. 담당 수석 매니저가 빠른 시일 내에 연락드리겠습니다."); 
                document.getElementById('stemConsultingForm').reset(); 
            })
            .catch(() => alert("오류가 발생했습니다."))
            .finally(() => { 
                btn.innerText = "제출하기"; 
                btn.disabled = false; 
            });
        });
    </script>
</body>
</html>
