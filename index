        function navigateTo(pageId, targetSectionId = null) {
            document.querySelectorAll('.page-content').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('nav ul li a').forEach(l => l.classList.remove('active'));
            
            const targetPage = document.getElementById('page-' + pageId);
            if (targetPage) { 
                targetPage.classList.add('active'); 
                
                if (targetSectionId) {
                    setTimeout(() => {
                        const section = document.getElementById('target-' + targetSectionId);
                        if (section) {
                            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }
                    }, 80);
                } else {
                    window.scrollTo({top:0, behavior:'smooth'}); 
                }
            }
            
            const link = document.getElementById('nav-' + pageId);
            if (link) link.classList.add('active');

            if (pageId === 'notices') { closeArticle(); renderCafeList(); }
        }

        function renderCafeList() {
            const tbody = document.getElementById('cafe-post-tbody');
            if(!tbody) return;
            tbody.innerHTML = '';
            cafeDatabase.forEach(post => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${post.isNotice ? '<span class="cafe-badge-notice">공지</span>' : post.id}</td>
                    <td class="cafe-title-td" onclick="openArticle(${post.id})">${post.title} <span class="comment-count-badge">[${post.comments.length}]</span></td>
                    <td style="color:#555;">${post.writer}</td>
                    <td style="color:#888;">${post.date}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function openArticle(id) {
            activeArticleId = id;
            const post = cafeDatabase.find(p => p.id === id);
            if (!post) return;
            document.getElementById('cafe-list-view').style.display = 'none';
            document.getElementById('cafe-detail-view').style.display = 'block';
            document.getElementById('detail-title').innerText = post.title;
            document.getElementById('detail-writer').innerText = post.writer;
            document.getElementById('detail-date').innerText = post.date;
            document.getElementById('detail-body').innerHTML = post.body;
            renderComments(post);
        }

        function closeArticle() {
            activeArticleId = null;
            document.getElementById('cafe-list-view').style.display = 'block';
            document.getElementById('cafe-detail-view').style.display = 'none';
            renderCafeList();
        }

        function renderComments(post) {
            const listUl = document.getElementById('article-comment-list');
            document.getElementById('comment-count').innerText = post.comments.length;
            listUl.innerHTML = '';
            if(post.comments.length === 0){
                listUl.innerHTML = `<li style="color:var(--text-muted); text-align:center; padding:1.5rem 0;">등록된 첫 댓글이 없습니다. 소중한 피드백을 남겨보세요.</li>`;
                return;
            }
            post.comments.forEach(c => {
                const li = document.createElement('li');
                li.className = 'comment-item';
                li.innerHTML = `
                    <div class="comment-meta"><span class="comment-writer">${c.writer}</span><span class="comment-date">${c.date}</span></div>
                    <div style="font-size:0.95rem; color:#444;">${c.content}</div>
                    <button class="comment-delete-btn" onclick="deleteComment(${post.id}, ${c.id})">삭제</button>
                `;
                listUl.appendChild(li);
            });
        }

        function addCommentSubmit() {
            if (!activeArticleId) return;
            const post = cafeDatabase.find(p => p.id === activeArticleId);
            const nick = document.getElementById('comment-nickname').value.trim();
            const text = document.getElementById('comment-content').value.trim();
            if(!nick || !text) { alert("닉네임과 본문을 빠짐없이 입력하세요."); return; }

            const now = new Date();
            const formattedDate = `${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
            const nextId = post.comments.length > 0 ? Math.max(...post.comments.map(c => c.id)) + 1 : 1;

            post.comments.push({ id: nextId, writer: nick, date: formattedDate, content: text });
            document.getElementById('comment-content').value = '';
            renderComments(post);
        }

        function deleteComment(postId, cId) {
            const post = cafeDatabase.find(p => p.id === postId);
            if(post) { post.comments = post.comments.filter(c => c.id !== cId); renderComments(post); }
        }

